# Optional: site name in the browser tab and Open Graph (default: Monzo UK). On Netlify, check you do not have an old value like "Monzo Bank UK" set here.
# NEXT_PUBLIC_SITE_NAME=Monzo UK

# Supabase - Create a project at https://supabase.com/dashboard
# Get these from: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service role key for admin KYC document viewing (Project Settings > API > service_role)
# Without this, admins can approve/reject KYC but cannot preview uploaded documents
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Finnhub - For live market indices (free at https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key
